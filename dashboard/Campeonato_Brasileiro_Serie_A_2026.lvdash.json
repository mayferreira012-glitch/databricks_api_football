{
  "datasets": [
    {
      "name": "7d618a42",
      "displayName": "Team Performance Metrics with Calculated Success Rate",
      "queryLines": [
        "select\r\n",
        "  *,\r\n",
        "  round(points / (matches * 3) * 100, 2) as rate\r\n",
        "from\r\n",
        "  team_statistics"
      ],
      "catalog": "api_football",
      "schema": "gold"
    },
    {
      "name": "970b65ab",
      "displayName": "players performance rankings with key statistics",
      "queryLines": [
        "select\r\n",
        "  *,\r\n",
        "  dense_rank() over(order by goals desc) as goals_rank,\r\n",
        "  dense_rank() over(order by assists desc) as assists_rank,\r\n",
        "  dense_rank() over(order by yellow_cards desc) as yellow_cards_rank,\r\n",
        "  dense_rank() over(order by red_cards desc) as red_cards_rank\r\n",
        "from\r\n",
        "  players_statistics"
      ],
      "catalog": "api_football",
      "schema": "gold"
    },
    {
      "name": "ac5771a4",
      "displayName": "Performance Metrics Overview Dataset",
      "queryLines": [
        "select * \n",
        "from acuracy_statistics\n",
        "order by shots_on_goal_pct desc"
      ],
      "catalog": "api_football",
      "schema": "gold"
    }
  ],
